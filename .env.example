# =============================================================================
# Agentic Document Intelligence — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your deployment.
#   cp .env.example .env
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
APP_PORT=8000
OLLAMA_PORT=11434
# API_KEY=your-secret-key-here        # Uncomment to enable API key auth
# CORS_ORIGINS=http://localhost:8000,http://localhost:3000  # Comma-separated allowed origins (include Next.js app)

# ── LLM Provider ────────────────────────────────────────────────────────────
# Options: ollama (default), vllm, gemini, openai
LLM_PROVIDER=ollama

# For Ollama (default, runs locally):
# Models are pulled automatically on first run.
#   VLM:          gemma3:4b (~3.2 GB)
#   OCR VLM:      deepseek-ocr (~3 GB)
#   Extraction:   phi3:mini (~2.5 GB)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=phi3:mini

# For Gemini (requires API key):
# GOOGLE_API_KEY=your_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# For OpenAI-compatible APIs (vLLM, etc.):
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=TheBloke/Llama-2-7B-Chat-GGUF

# ── Performance ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100
TIMEOUT_SECONDS=300
